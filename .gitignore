# ─────────────────────────────────────────────────────────
# Laravel - Ignorar dependencias, compilados y entornos
# ─────────────────────────────────────────────────────────
/vendor
/node_modules
.env
.env.*
/.env.*
/.env.backup
.env.production

# Laravel - Ignorar archivos generados automáticamente
/public/hot
/public/storage
/public/build
/storage/*.key
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
.phpunit.result.cache
/.phpunit.cache

# Laravel - Homestead
Homestead.yaml
Homestead.json

# ─────────────────────────────────────────────────────────
